{
  "$schema": "https://opencode.ai/config.json",
  "username": "Jiyeol Lee",
  "default_agent": "primary/plan",
  "autoupdate": false,
  "plugin": ["@ex-machina/opencode-anthropic-auth@1.4.0"],
  "model": "opencode-go/minimax-m2.7",
  "permission": {
    "mcp__*": "deny",
    "tool__*": "deny",
    "doom_loop": "deny",
    "external_directory": {
      "~/.config/opencode/**": "allow"
    },
    "skill": {
      "*": "deny"
    }
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "mcp__context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "mcp__aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "mcp__linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      },
      "enabled": false
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "primary/plan": {
      "description": "Research and task planning orchestrator",
      "temperature": 0.3,
      "mode": "primary",
      "prompt": "{file:./prompts/agent/primary/plan.md}",
      "permission": {
        "bash": "deny",
        "read": "allow",
        "write": "deny",
        "edit": "deny",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "patch": "deny",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "subagent/researcher": "allow",
          "subagent/planner": "allow",
          "subagent/requirements-refiner": "allow"
        }
      }
    },
    "primary/build": {
      "description": "Build orchestrator - delegates development tasks to specialized sub-agents",
      "temperature": 0.1,
      "mode": "primary",
      "prompt": "{file:./prompts/agent/primary/build.md}",
      "permission": {
        "bash": "deny",
        "read": "allow",
        "write": "deny",
        "edit": "deny",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "patch": "deny",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "subagent/researcher": "allow",
          "subagent/generator": "allow",
          "subagent/evaluator": "allow"
        }
      }
    },
    "primary/lawyer": {
      "description": "Legal advice specialist",
      "mode": "primary",
      "prompt": "{file:./prompts/agent/primary/lawyer.md}",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "deny",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "allow",
        "question": "allow",
        "task": "deny"
      }
    },
    "subagent/researcher": {
      "description": "Information gathering specialist for searching code and documentation",
      "temperature": 0.1,
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/researcher.md}",
      "permission": {
        "bash": {
          "*": "deny",
          "playwright-cli *": "allow",
          "sleep *": "allow"
        },
        "edit": "deny",
        "write": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "allow",
        "question": "allow",
        "mcp__context7_*": "allow",
        "mcp__aws-knowledge_*": "allow",
        "mcp__linear_*": "allow",
        "mcp__atlassian_*": "allow",
        "tool__gh--retrieve-pull-request-info": "allow",
        "tool__gh--retrieve-pull-request-diff": "allow",
        "tool__git--retrieve-current-branch-diff": "allow",
        "tool__gh--retrieve-repository-dependabot-alerts": "allow"
      },
      "skill": {
        "playwright-cli": "allow"
      }
    },
    "subagent/planner": {
      "description": "Creates and updates Product Requirements Documents (PRDs) and task breakdowns. Receives context from primary/plan and delivers planning documents.",
      "temperature": 0.1,
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/planner.md}",
      "permission": {
        "bash": {
          "*": "deny",
          "git config --get user.name": "allow",
          "git config --get user.email": "allow"
        },
        "read": "allow",
        "write": {
          "*": "deny",
          "__docs/**/*.md": "allow"
        },
        "edit": {
          "*": "deny",
          "__docs/**/*.md": "allow"
        },
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "deny",
        "question": "deny",
        "skill": {
          "prd": "allow",
          "task-breakdown": "allow"
        }
      }
    },
    "subagent/requirements-refiner": {
      "description": "Reviews requirements using grill-me to surface gaps, ambiguities, and untestable criteria",
      "temperature": 0.1,
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/requirements-refiner.md}",
      "permission": {
        "bash": {
          "*": "deny",
          "playwright-cli *": "allow",
          "sleep *": "allow"
        },
        "read": "allow",
        "write": "deny",
        "edit": "deny",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "deny",
        "question": "deny",
        "skill": {
          "prd": "allow",
          "task-breakdown": "allow",
          "grill-me": "allow",
          "playwright-cli": "allow"
        }
      }
    },
    "subagent/generator": {
      "description": "Writes code, documentation, and runs validation. Proposes contracts and self-evaluates before handoff to evaluator. Part of the GAN-inspired build loop.",
      "temperature": 0.1,
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/generator.md}",
      "permission": {
        "bash": {
          "*": "ask",
          "rg *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow",
          "echo *": "allow",
          "wc *": "allow",
          "grep *": "allow",
          "sort *": "allow",
          "pwd *": "allow",
          "tree *": "allow",
          "git worktree *": "deny",
          "git checkout *": "deny",
          "git stash *": "deny",
          "git pop *": "deny",
          "git log *": "allow",
          "git show *": "allow",
          "git status *": "allow",
          "git diff *": "allow",
          "go build *": "allow",
          "go test *": "allow",
          "go vet *": "allow",
          "go fmt *": "allow"
        },
        "edit": "allow",
        "write": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "allow",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "deny",
        "question": "deny",
        "skill": {
          "code": "allow",
          "document": "allow",
          "devops": "allow",
          "check": "allow",
          "commit": "allow",
          "pull-request": "allow",
          "review-validation": "allow",
          "skill-creator": "allow",
          "agent-creator": "allow"
        },
        "mcp__context7_*": "allow",
        "mcp__aws-knowledge_*": "allow",
        "tool__gh--retrieve-pull-request-info": "allow",
        "tool__gh--retrieve-pull-request-diff": "allow",
        "tool__gh--retrieve-repository-dependabot-alerts": "allow",
        "tool__gh--retrieve-repository-collaborators": "allow",
        "tool__gh--create-pull-request": "allow",
        "tool__gh--edit-pull-request": "allow",
        "tool__git--retrieve-current-branch-diff": "allow",
        "tool__git--retrieve-latest-n-commits-diff": "allow",
        "tool__git--status": "allow",
        "tool__git--stage-files": "allow",
        "tool__git--commit": "allow",
        "tool__git--push": "allow"
      }
    },
    "subagent/evaluator": {
      "description": "Critiques code, reviews changes, runs e2e tests. Grades against criteria with hard thresholds and provides detailed feedback. Part of the GAN-inspired build loop.",
      "temperature": 0.1,
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/evaluator.md}",
      "permission": {
        "bash": {
          "*": "ask",
          "rg *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow",
          "echo *": "allow",
          "wc *": "allow",
          "grep *": "allow",
          "sort *": "allow",
          "pwd *": "allow",
          "tree *": "allow",
          "git worktree *": "deny",
          "git checkout *": "deny",
          "git stash *": "deny",
          "git pop *": "deny",
          "git log *": "allow",
          "git show *": "allow",
          "git status *": "allow",
          "git diff *": "allow",
          "playwright-cli *": "allow",
          "sleep *": "allow",
          "go build *": "allow",
          "go test *": "allow",
          "go vet *": "allow",
          "go fmt *": "allow"
        },
        "edit": "deny",
        "write": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "deny",
        "question": "deny",
        "skill": {
          "check": "allow",
          "review-validation": "allow",
          "review": "allow",
          "playwright-cli": "allow"
        },
        "mcp__context7_*": "allow",
        "mcp__aws-knowledge_*": "allow",
        "tool__gh--retrieve-pull-request-info": "allow",
        "tool__gh--retrieve-pull-request-diff": "allow",
        "tool__gh--retrieve-repository-dependabot-alerts": "allow",
        "tool__gh--retrieve-repository-collaborators": "allow",
        "tool__git--retrieve-current-branch-diff": "allow",
        "tool__git--retrieve-latest-n-commits-diff": "allow",
        "tool__git--status": "allow"
      }
    }
  }
}
