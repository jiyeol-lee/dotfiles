{
  "$schema": "https://opencode.ai/config.json",
  "username": "Jiyeol Lee",
  "default_agent": "primary/plan",
  "autoupdate": false,
  "model": "opencode-go/minimax-m2.7",
  "permission": {
    "mcp__*": "deny",
    "tool__*": "deny",
    "doom_loop": "deny",
    "external_directory": {
      "~/.config/opencode/**": "allow"
    },
    "skill": {
      "*": "deny"
    }
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "mcp__context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "mcp__aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "mcp__linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      },
      "enabled": false
    },
    "mcp__atlassian": {
      "type": "local",
      "command": ["npx", "mcp-remote", "https://mcp.atlassian.com/v1/mcp"],
      "enabled": false
    },
    "mcp__playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "primary/plan": {
      "description": "Research and task planning orchestrator",
      "temperature": 0.3,
      "mode": "primary",
      "prompt": "{file:./prompts/agent/primary/plan.md}",
      "permission": {
        "bash": {
          "*": "deny",
          "git config --get user.name": "allow",
          "git config --get user.email": "allow"
        },
        "read": "allow",
        "write": {
          "*": "deny",
          "__docs/**/*.md": "allow"
        },
        "edit": {
          "*": "deny",
          "__docs/**/*.md": "allow"
        },
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "patch": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "subagent/researcher": "allow"
        },
        "skill": {
          "grill-me": "allow",
          "prd": "allow",
          "task-breakdown": "allow"
        }
      }
    },
    "primary/build": {
      "description": "Build orchestrator - delegates development tasks to specialized sub-agents",
      "temperature": 0.1,
      "mode": "primary",
      "prompt": "{file:./prompts/agent/primary/build.md}",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "list": "deny",
        "patch": "deny",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "subagent/software-engineer": "allow"
        }
      }
    },
    "subagent/researcher": {
      "description": "Information gathering specialist for searching code and documentation",
      "temperature": 0.1,
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/researcher.md}",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "allow",
        "question": "allow",
        "mcp__context7_*": "allow",
        "mcp__aws-knowledge_*": "allow",
        "mcp__linear_*": "allow",
        "mcp__atlassian_*": "allow",
        "tool__gh--retrieve-pull-request-info": "allow",
        "tool__gh--retrieve-pull-request-diff": "allow",
        "tool__git--retrieve-current-branch-diff": "allow",
        "tool__gh--retrieve-repository-dependabot-alerts": "allow"
      }
    },
    "subagent/software-engineer": {
      "description": "Full-stack software engineer with skills for code implementation, documentation, DevOps, testing, and code review",
      "temperature": 0.1,
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/software-engineer.md}",
      "permission": {
        "bash": {
          "*": "ask",
          "rg *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow",
          "echo *": "allow",
          "wc *": "allow",
          "grep *": "allow",
          "git worktree *": "deny",
          "git checkout *": "deny",
          "git stash *": "deny",
          "git pop *": "deny",
          "git log *": "allow",
          "git show *": "allow",
          "git status *": "allow",
          "git diff *": "allow"
        },
        "edit": "allow",
        "write": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "allow",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "deny",
        "question": "deny",
        "skill": {
          "code": "allow",
          "document": "allow",
          "devops": "allow",
          "e2e-test": "allow",
          "check": "allow",
          "commit": "allow",
          "pull-request": "allow",
          "review": "allow",
          "review-validation": "allow",
          "skill-creator": "allow"
        },
        "mcp__context7_*": "allow",
        "mcp__aws-knowledge_*": "allow",
        "mcp__playwright_*": "allow",
        "mcp__linear_*": "allow",
        "mcp__atlassian_*": "allow",
        "tool__gh--retrieve-pull-request-info": "allow",
        "tool__gh--retrieve-pull-request-diff": "allow",
        "tool__gh--retrieve-repository-dependabot-alerts": "allow",
        "tool__gh--retrieve-repository-collaborators": "allow",
        "tool__gh--create-pull-request": "allow",
        "tool__gh--edit-pull-request": "allow",
        "tool__git--retrieve-current-branch-diff": "allow",
        "tool__git--retrieve-latest-n-commits-diff": "allow",
        "tool__git--status": "allow",
        "tool__git--stage-files": "allow",
        "tool__git--commit": "allow",
        "tool__git--push": "allow"
      }
    }
  }
}
