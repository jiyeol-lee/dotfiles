{
  "$schema": "https://opencode.ai/config.json",
  "username": "Jiyeol Lee",
  "default_agent": "primary/plan",
  "autoupdate": false,
  "model": "opencode-go/minimax-m2.7",
  "permission": {
    "mcp__*": "deny",
    "tool__*": "deny",
    "doom_loop": "deny",
    "skill": "deny"
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "mcp__context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "mcp__aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "mcp__linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      },
      "enabled": false
    },
    "mcp__atlassian": {
      "type": "local",
      "command": ["npx", "mcp-remote", "https://mcp.atlassian.com/v1/mcp"],
      "enabled": false
    },
    "mcp__playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "primary/plan": {
      "description": "Research and task planning orchestrator",
      "mode": "primary",
      "prompt": "{file:./prompts/agent/primary/plan.md}",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "list": "deny",
        "patch": "deny",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "subagent/research": "allow",
          "subagent/task": "allow"
        }
      }
    },
    "primary/build": {
      "description": "Build orchestrator - delegates development tasks to specialized sub-agents",
      "mode": "primary",
      "prompt": "{file:./prompts/agent/primary/build.md}",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "list": "deny",
        "patch": "deny",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "subagent/code": "allow",
          "subagent/document": "allow",
          "subagent/devops": "allow",
          "subagent/e2e-test": "allow",
          "subagent/check": "allow",
          "subagent/review": "allow",
          "subagent/commit": "allow",
          "subagent/pull-request": "allow",
          "subagent/review-validation": "allow"
        }
      }
    },
    "subagent/check": {
      "description": "Validation specialist for code quality checks (linting, type-checking, formatting, unit/integration tests)",
      "mode": "subagent",
      "hidden": true,
      "prompt": "{file:./prompts/agent/subagent/check.md}",
      "permission": {
        "bash": "allow",
        "edit": "deny",
        "write": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "patch": "deny",
        "todowrite": "deny",
        "todoread": "deny",
        "webfetch": "deny",
        "question": "deny"
